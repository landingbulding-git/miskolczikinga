---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
---

<Layout title="Hovorka-Miskolczi Kinga">
	<div class="min-h-screen bg-cream-100 selection:bg-gold-200 selection:text-charcoal-900 overflow-x-hidden antialiased">
		<!-- Luxury Top Accents Line -->
		<div class="h-1.5 w-full bg-gradient-to-r from-gold-300 via-gold-400 to-gold-600 sticky top-0 z-50 pointer-events-none"></div>

		<Navbar currentPage="home" client:load />

		<main class="flex items-center justify-center min-h-[calc(100vh-200px)]">
			<div class="text-center px-4">
				<h1 class="text-4xl md:text-5xl font-bold text-charcoal-900 mb-4">Placeholder Home Page</h1>
				<p class="text-lg text-charcoal-700 mb-8">Content coming soon</p>
			</div>
		</main>

		<Footer client:visible />
	</div>
</Layout>
