---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/shared/Navbar';
import HomeHero from '../components/home/HomeHero';
import HomeServices from '../components/home/HomeServices';
import HomeMedia from '../components/home/HomeMedia';
import HomeCaseStudies from '../components/home/HomeCaseStudies';
import MainCloser from '../components/home/MainCloser';
import Footer from '../components/shared/Footer';
---

<Layout title="Hovorka-Miskolczi Kinga">
	<div class="min-h-screen bg-cream-100 selection:bg-gold-200 selection:text-charcoal-900 overflow-x-hidden antialiased">
		<!-- Luxury Top Accents Line -->
		<div class="h-1.5 w-full bg-gradient-to-r from-gold-300 via-gold-400 to-gold-600 sticky top-0 z-50 pointer-events-none"></div>

		<Navbar currentPage="home" client:load />

		<HomeHero client:load />
		<HomeServices client:visible />
		<HomeMedia client:visible />
		<HomeCaseStudies client:visible />
		<MainCloser client:visible />
		<Footer client:visible />
	</div>
</Layout>
